{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YARA Studio",
  "version": "0.1.0",
  "identifier": "com.platinum2high.yara-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "YARA Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 620,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0d1017"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
